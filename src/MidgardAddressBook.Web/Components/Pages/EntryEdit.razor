@page "/entries/new"
@page "/entries/{Id:int}"
@rendermode InteractiveServer
@inject IAddressBookService AddressBookService
@inject NavigationManager Navigation

<PageTitle>@(IsNew ? "New Contact" : "Edit Contact") — Midgard Address Book</PageTitle>

<div class="mb-4">
    <a href="/" class="btn btn-link ps-0 text-decoration-none"><i class="fa-solid fa-arrow-left me-1" aria-hidden="true"></i> Back to contacts</a>
</div>

<div class="card shadow-sm mx-auto" style="max-width: 720px;">
    <div class="card-header bg-transparent py-3">
        <h1 class="h4 mb-0 fw-semibold">@(IsNew ? "Add New Contact" : "Edit Contact")</h1>
    </div>
    <div class="card-body p-4">
        <EditForm Model="Model" OnValidSubmit="SaveAsync" FormName="entry-form">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger small mb-3" />
            <input type="hidden" name="Model.Id" value="@Model.Id" />

            <fieldset class="row g-3">
                <legend class="col-12 col-form-label fw-medium pb-0 pt-0">Name</legend>

                <div class="col-md-6">
                    <label for="firstName" class="form-label">First name</label>
                    <input id="firstName" name="Model.FirstName" class="form-control" @bind="Model.FirstName" placeholder="Jane" />
                </div>
                <div class="col-md-6">
                    <label for="lastName" class="form-label">Last name</label>
                    <input id="lastName" name="Model.LastName" class="form-control" @bind="Model.LastName" placeholder="Smith" />
                </div>
            </fieldset>

            <hr class="my-3" />

            <fieldset class="row g-3">
                <legend class="col-12 col-form-label fw-medium pb-0 pt-0">Contact details</legend>

                <div class="col-md-6">
                    <label for="email" class="form-label">Email</label>
                    <input id="email" name="Model.Email" type="email" class="form-control" @bind="Model.Email" placeholder="jane@example.com" />
                </div>
                <div class="col-md-6">
                    <label for="phone" class="form-label">Phone</label>
                    <input id="phone" name="Model.Phone" type="tel" class="form-control" @bind="Model.Phone" placeholder="+1 (555) 000-0000" />
                </div>
            </fieldset>

            <hr class="my-3" />

            <fieldset class="row g-3">
                <legend class="col-12 col-form-label fw-medium pb-0 pt-0">Address</legend>

                <div class="col-12">
                    <label for="address1" class="form-label">Address line 1</label>
                    <input id="address1" name="Model.Address1" class="form-control" @bind="Model.Address1" placeholder="123 Main St" />
                </div>
                <div class="col-12">
                    <label for="address2" class="form-label">
                        Address line 2
                        <span class="text-body-secondary fw-normal">(optional)</span>
                    </label>
                    <input id="address2" name="Model.Address2" class="form-control" @bind="Model.Address2" placeholder="Apt 4B" />
                </div>

                <div class="col-md-5">
                    <label for="city" class="form-label">City</label>
                    <input id="city" name="Model.City" class="form-control" @bind="Model.City" placeholder="Asgard" />
                </div>
                <div class="col-md-4">
                    <label for="state" class="form-label">State</label>
                    <input id="state" name="Model.State" class="form-control" @bind="Model.State" placeholder="NY" />
                </div>
                <div class="col-md-3">
                    <label for="zipCode" class="form-label">ZIP</label>
                    <input id="zipCode" name="Model.ZipCode" class="form-control" @bind="Model.ZipCode" placeholder="10001" />
                </div>
            </fieldset>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4">
                    <i class="fa-solid fa-floppy-disk me-1" aria-hidden="true"></i>@(IsNew ? "Create Contact" : "Save Changes")
                </button>
                <a href="/" class="btn btn-outline-secondary"><i class="fa-solid fa-xmark me-1" aria-hidden="true"></i> Cancel</a>
            </div>
        </EditForm>
    </div>
</div>

@code {
    /// <summary>Route parameter: entry id. Null/0 means create.</summary>
    [Parameter] public int? Id { get; set; }

    /// <summary>
    /// Form-backed model. Marked with <see cref="SupplyParameterFromFormAttribute"/>
    /// so Blazor rehydrates the posted form values on submit when using enhanced
    /// navigation in a .NET 8+ Blazor Web App.
    /// </summary>
    [SupplyParameterFromForm(FormName = "entry-form")]
    public AddressBookEntryDto Model { get; set; } = default!;

    private bool IsNew => Id is null or 0;

    protected override void OnInitialized()
    {
        // Establish a default when the form is not being posted back.
        // On a POST, Blazor rehydrates Model from the form body before this runs.
        Model ??= new AddressBookEntryDto();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (IsNew)
        {
            // Reset when the same component instance is reused after navigating from an edit
            // route to the "new" route (e.g., /entries/5 → /entries/new).
            if (Model.Id != 0)
            {
                Model = new AddressBookEntryDto();
            }
            return;
        }

        // Edit mode: load from the service on the initial GET, or whenever the route parameter
        // changes (e.g., navigating /entries/5 → /entries/6 reuses the same component instance).
        // On a form post, Model.Id equals the posted id, so the condition is false and the reload
        // is correctly skipped.
        if (Model.Id != Id!.Value)
        {
            Model = await AddressBookService.GetByIdAsync(Id!.Value) ?? new AddressBookEntryDto { Id = Id!.Value };
        }
    }

    private async Task SaveAsync()
    {
        if (IsNew)
        {
            await AddressBookService.CreateAsync(Model);
        }
        else
        {
            await AddressBookService.UpdateAsync(Model);
        }

        Navigation.NavigateTo("/");
    }
}
