@page "/"
@page "/splash"

<PageTitle>Midgard Address Book</PageTitle>

<div class="splash-hero d-flex flex-column justify-content-center align-items-center text-center px-3">

    <div class="splash-icon mb-4" aria-hidden="true">
        <i class="fa-solid fa-address-book"></i>
    </div>

    <h1 class="display-4 fw-bold mb-3">Midgard Address Book</h1>

    <p class="lead text-body-secondary mb-5 splash-tagline">
        Keep your allies close.<br class="d-none d-sm-inline" />
        Manage your contacts across the Nine Realms.
    </p>

    <a href="/contacts" class="btn btn-primary btn-lg px-5 py-3 splash-cta shadow">
        <i class="fa-solid fa-address-book me-2" aria-hidden="true"></i>
        Start Address Book
    </a>

</div>
