@page "/entries/new"
@page "/entries/{Id:int}"
@rendermode InteractiveServer
@inject IAddressBookService AddressBookService
@inject NavigationManager Navigation

<PageTitle>@(IsNew ? "New contact" : "Edit contact")</PageTitle>

<div class="container mt-4" style="max-width: 720px;">
    <h1 class="h3 mb-3">@(IsNew ? "New contact" : "Edit contact")</h1>

    <EditForm Model="Model" OnValidSubmit="SaveAsync" FormName="entry-form">
        <DataAnnotationsValidator />
        <ValidationSummary class="text-danger" />

        <input type="hidden" name="Model.Id" value="@Model.Id" />

        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">First name</label>
                <InputText class="form-control" @bind-Value="Model.FirstName" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Last name</label>
                <InputText class="form-control" @bind-Value="Model.LastName" />
            </div>

            <div class="col-md-6">
                <label class="form-label">Email</label>
                <InputText class="form-control" @bind-Value="Model.Email" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Phone</label>
                <InputText class="form-control" @bind-Value="Model.Phone" />
            </div>

            <div class="col-12">
                <label class="form-label">Address 1</label>
                <InputText class="form-control" @bind-Value="Model.Address1" />
            </div>
            <div class="col-12">
                <label class="form-label">Address 2</label>
                <InputText class="form-control" @bind-Value="Model.Address2" />
            </div>

            <div class="col-md-5">
                <label class="form-label">City</label>
                <InputText class="form-control" @bind-Value="Model.City" />
            </div>
            <div class="col-md-4">
                <label class="form-label">State</label>
                <InputText class="form-control" @bind-Value="Model.State" />
            </div>
            <div class="col-md-3">
                <label class="form-label">ZIP</label>
                <InputText class="form-control" @bind-Value="Model.ZipCode" />
            </div>
        </div>

        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Save</button>
            <a href="/" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </EditForm>
</div>

@code {
    /// <summary>Route parameter: entry id. Null/0 means create.</summary>
    [Parameter] public int? Id { get; set; }

    /// <summary>
    /// Form-backed model. Marked with <see cref="SupplyParameterFromFormAttribute"/>
    /// so Blazor rehydrates the posted form values on submit when using enhanced
    /// navigation in a .NET 8+ Blazor Web App.
    /// </summary>
    [SupplyParameterFromForm(FormName = "entry-form")]
    public AddressBookEntryDto Model { get; set; } = default!;

    private bool IsNew => Id is null or 0;

    protected override void OnInitialized()
    {
        // Establish a default when the form is not being posted back.
        // On a POST, Blazor rehydrates Model from the form body before this runs.
        Model ??= new AddressBookEntryDto();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (IsNew)
        {
            // Reset when the same component instance is reused after navigating from an edit
            // route to the "new" route (e.g., /entries/5 → /entries/new).
            if (Model.Id != 0)
            {
                Model = new AddressBookEntryDto();
            }
            return;
        }

        // Edit mode: load from the service on the initial GET, or whenever the route parameter
        // changes (e.g., navigating /entries/5 → /entries/6 reuses the same component instance).
        // On a form post, Model.Id equals the posted id, so the condition is false and the reload
        // is correctly skipped.
        if (Model.Id != Id!.Value)
        {
            Model = await AddressBookService.GetByIdAsync(Id!.Value) ?? new AddressBookEntryDto { Id = Id!.Value };
        }
    }

    private async Task SaveAsync()
    {
        if (IsNew)
        {
            await AddressBookService.CreateAsync(Model);
        }
        else
        {
            await AddressBookService.UpdateAsync(Model);
        }

        Navigation.NavigateTo("/");
    }
}
